{
  "schema_version": "0.1",
  "id": "kitchen-scale",
  "name": "Kitchen scale (HX711 + OLED readout)",
  "description": "WeMos D1 Mini reading a load cell through an HX711 24-bit ADC and displaying grams on a 128x64 SSD1306 OLED. The HX711's 2-wire serial (DOUT/SCK) is bit-banged on two GPIOs; the OLED shares an I2C bus on the standard D1/D2 pins.",
  "created_at": "2026-05-15T00:00:00Z",
  "updated_at": "2026-05-15T00:00:00Z",

  "board": {
    "library_id": "wemos-d1-mini",
    "mcu": "esp8266",
    "framework": "arduino"
  },

  "power": {
    "supply": "usb-5v",
    "rail_voltage_v": 5.0,
    "regulator": "onboard-rt9013",
    "budget_ma": 500
  },

  "requirements": [
    { "id": "r1", "kind": "capability", "text": "report weight in grams from a load cell via HX711" },
    { "id": "r2", "kind": "capability", "text": "show the live weight on a small OLED" },
    { "id": "r3", "kind": "constraint", "text": "HX711 protocol is custom 2-wire serial -- not I2C, not SPI" }
  ],

  "components": [
    {
      "id": "scale",
      "library_id": "hx711",
      "label": "Kitchen scale",
      "params": {
        "gain": 128,
        "update_interval": "500ms",
        "filters": [{ "calibrate_linear": ["0 -> 0", "200000 -> 1000"] }, { "lambda": "return x;" }]
      }
    },
    {
      "id": "oled1",
      "library_id": "ssd1306",
      "label": "Scale display",
      "role": "display",
      "params": {
        "address": "0x3C",
        "update_interval": "200ms",
        "lambda_": "it.printf(0, 0, id(font1), \"Weight\");\nit.printf(0, 24, id(font2), \"%.0f g\", id(scale).state);\n"
      }
    }
  ],

  "buses": [
    { "id": "i2c0", "type": "i2c", "frequency_hz": 400000, "sda": "D2", "scl": "D1" }
  ],

  "connections": [
    { "component_id": "scale", "pin_role": "VCC",  "target": { "kind": "rail", "rail": "3V3" } },
    { "component_id": "scale", "pin_role": "GND",  "target": { "kind": "rail", "rail": "GND" } },
    { "component_id": "scale", "pin_role": "DOUT", "target": { "kind": "gpio", "pin": "D5" } },
    { "component_id": "scale", "pin_role": "SCK",  "target": { "kind": "gpio", "pin": "D6" } },

    { "component_id": "oled1", "pin_role": "VCC",   "target": { "kind": "rail", "rail": "3V3" } },
    { "component_id": "oled1", "pin_role": "GND",   "target": { "kind": "rail", "rail": "GND" } },
    { "component_id": "oled1", "pin_role": "SDA",   "target": { "kind": "bus",  "bus_id": "i2c0" } },
    { "component_id": "oled1", "pin_role": "SCL",   "target": { "kind": "bus",  "bus_id": "i2c0" } },
    { "component_id": "oled1", "pin_role": "RESET", "target": { "kind": "gpio", "pin": "D0" } }
  ],

  "passives": [
    { "id": "c1", "kind": "capacitor", "value": "100nF", "between": ["scale.VCC", "GND"], "purpose": "decoupling scale" },
    { "id": "c2", "kind": "capacitor", "value": "10uF",  "between": ["scale.VCC", "GND"], "purpose": "bulk decoupling for the load-cell front-end" },
    { "id": "c3", "kind": "capacitor", "value": "100nF", "between": ["oled1.VCC", "GND"], "purpose": "decoupling oled1" },
    { "id": "r1", "kind": "resistor",  "value": "4.7k",  "between": ["i2c0.SDA", "3V3"],  "purpose": "I2C pull-up" },
    { "id": "r2", "kind": "resistor",  "value": "4.7k",  "between": ["i2c0.SCL", "3V3"],  "purpose": "I2C pull-up" }
  ],

  "warnings": [],

  "esphome_extras": {
    "captive_portal": {},
    "logger": {},
    "font": [
      { "file": "gfonts://Roboto", "id": "font1", "size": 14 },
      { "file": "gfonts://Roboto", "id": "font2", "size": 28 }
    ]
  },

  "fleet": {
    "device_name": "kitchen-scale",
    "tags": ["indoor", "kitchen", "scale"],
    "secrets_ref": {
      "wifi_ssid": "!secret wifi_ssid",
      "wifi_password": "!secret wifi_password",
      "api_key": "!secret api_key"
    }
  }
}

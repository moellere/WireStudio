{
  "schema_version": "0.1",
  "id": "attic-logger",
  "name": "Attic climate logger (legacy parts)",
  "description": "WeMos D1 Mini logging temperature/humidity from a DHT22 on a GPIO and barometric pressure from an older BMP180 on I2C -- a 'parts box' build pairing the single-wire DHT protocol with a legacy I2C barometer people already have on hand.",
  "created_at": "2026-05-15T00:00:00Z",
  "updated_at": "2026-05-15T00:00:00Z",

  "board": {
    "library_id": "wemos-d1-mini",
    "mcu": "esp8266",
    "framework": "arduino"
  },

  "power": {
    "supply": "usb-5v",
    "rail_voltage_v": 5.0,
    "regulator": "onboard-rt9013",
    "budget_ma": 500
  },

  "requirements": [
    { "id": "r1", "kind": "capability",  "text": "report attic temperature + humidity from a DHT22" },
    { "id": "r2", "kind": "capability",  "text": "report barometric pressure from a legacy BMP180" },
    { "id": "r3", "kind": "constraint",  "text": "DHT22 is single-wire (one GPIO); BMP180 is I2C-only at the fixed 0x77 address" }
  ],

  "components": [
    {
      "id": "th",
      "library_id": "dht",
      "label": "Attic climate",
      "params": { "model": "DHT22", "update_interval": "60s" }
    },
    {
      "id": "baro",
      "library_id": "bmp180",
      "label": "Attic pressure",
      "params": { "update_interval": "60s" }
    }
  ],

  "buses": [
    { "id": "i2c0", "type": "i2c", "frequency_hz": 100000, "sda": "D2", "scl": "D1" }
  ],

  "connections": [
    { "component_id": "th",   "pin_role": "VCC",  "target": { "kind": "rail", "rail": "3V3" } },
    { "component_id": "th",   "pin_role": "GND",  "target": { "kind": "rail", "rail": "GND" } },
    { "component_id": "th",   "pin_role": "DATA", "target": { "kind": "gpio", "pin": "D5" } },

    { "component_id": "baro", "pin_role": "VCC",  "target": { "kind": "rail", "rail": "3V3" } },
    { "component_id": "baro", "pin_role": "GND",  "target": { "kind": "rail", "rail": "GND" } },
    { "component_id": "baro", "pin_role": "SDA",  "target": { "kind": "bus",  "bus_id": "i2c0" } },
    { "component_id": "baro", "pin_role": "SCL",  "target": { "kind": "bus",  "bus_id": "i2c0" } }
  ],

  "passives": [
    { "id": "c1", "kind": "capacitor", "value": "100nF", "between": ["th.VCC", "GND"],   "purpose": "decoupling th" },
    { "id": "c2", "kind": "capacitor", "value": "100nF", "between": ["baro.VCC", "GND"], "purpose": "decoupling baro" },
    { "id": "r1", "kind": "resistor",  "value": "10k",   "between": ["th.DATA", "3V3"],  "purpose": "DHT22 data-line pull-up" },
    { "id": "r2", "kind": "resistor",  "value": "4.7k",  "between": ["i2c0.SDA", "3V3"], "purpose": "I2C pull-up" },
    { "id": "r3", "kind": "resistor",  "value": "4.7k",  "between": ["i2c0.SCL", "3V3"], "purpose": "I2C pull-up" }
  ],

  "warnings": [],

  "esphome_extras": {
    "captive_portal": {},
    "logger": {}
  },

  "fleet": {
    "device_name": "attic-logger",
    "tags": ["indoor", "climate", "legacy"],
    "secrets_ref": {
      "wifi_ssid": "!secret wifi_ssid",
      "wifi_password": "!secret wifi_password",
      "api_key": "!secret api_key"
    }
  }
}

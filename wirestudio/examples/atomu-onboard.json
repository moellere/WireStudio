{
  "schema_version": "0.1",
  "id": "atomu-onboard",
  "name": "M5Stack AtomU (onboard)",
  "description": "M5Stack AtomU (USB-A stick) with its onboard parts pre-placed: SK6812 RGB LED, the button, the IR transmitter, and the SPM1423 PDM microphone -- the full onboard set the studio auto-populates.",
  "created_at": "2026-05-23T00:00:00Z",
  "updated_at": "2026-05-23T00:00:00Z",
  "board": {
    "library_id": "m5stack-atomu",
    "mcu": "esp32",
    "framework": "arduino"
  },
  "power": {
    "supply": "usb-5v",
    "rail_voltage_v": 5.0,
    "regulator": "onboard",
    "budget_ma": 500
  },
  "requirements": [
    {
      "id": "r1",
      "kind": "capability",
      "text": "expose the AtomU's built-in LED, button, IR, and mic"
    }
  ],
  "components": [
    {
      "id": "onboard_led",
      "library_id": "esp32_rmt_led_strip",
      "label": "Onboard RGB LED",
      "params": {
        "num_leds": 1,
        "chipset": "SK6812"
      }
    },
    {
      "id": "onboard_button",
      "library_id": "gpio_input",
      "label": "Onboard button",
      "params": {
        "filters": [
          {
            "invert": null
          }
        ]
      }
    },
    {
      "id": "onboard_ir",
      "library_id": "remote_transmitter",
      "label": "Onboard IR blaster",
      "params": {}
    },
    {
      "id": "onboard_mic",
      "library_id": "i2s_microphone",
      "label": "Onboard microphone",
      "params": {
        "pdm": true
      }
    }
  ],
  "buses": [],
  "connections": [
    {
      "component_id": "onboard_led",
      "pin_role": "VCC",
      "target": {
        "kind": "rail",
        "rail": "5V"
      }
    },
    {
      "component_id": "onboard_led",
      "pin_role": "GND",
      "target": {
        "kind": "rail",
        "rail": "GND"
      }
    },
    {
      "component_id": "onboard_led",
      "pin_role": "DIN",
      "target": {
        "kind": "gpio",
        "pin": "GPIO27"
      }
    },
    {
      "component_id": "onboard_button",
      "pin_role": "IN",
      "target": {
        "kind": "gpio",
        "pin": "GPIO39"
      }
    },
    {
      "component_id": "onboard_ir",
      "pin_role": "IR",
      "target": {
        "kind": "gpio",
        "pin": "GPIO12"
      }
    },
    {
      "component_id": "onboard_mic",
      "pin_role": "WS",
      "target": {
        "kind": "gpio",
        "pin": "GPIO5"
      }
    },
    {
      "component_id": "onboard_mic",
      "pin_role": "DIN",
      "target": {
        "kind": "gpio",
        "pin": "GPIO19"
      }
    }
  ],
  "passives": [],
  "warnings": [],
  "esphome_extras": {
    "captive_portal": {},
    "logger": {}
  },
  "fleet": {
    "device_name": "atomu-onboard",
    "tags": [
      "onboard"
    ],
    "secrets_ref": {
      "wifi_ssid": "!secret wifi_ssid",
      "wifi_password": "!secret wifi_password",
      "api_key": "!secret api_key"
    }
  }
}

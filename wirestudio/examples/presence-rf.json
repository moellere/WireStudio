      "type": "uart",
      "tx": "GPIO17",
      "rx": "GPIO16",
      "baud_rate": 115200
    },
    {
      "id": "rf_uart",
      "type": "uart",
      "tx": "GPIO19",
      "rx": "GPIO18",
      "baud_rate": 19200
    }
  ],

// Generated by wirestudio (lorawan target). Do not edit by hand.
// Device: {{ device_name }}
// Board:  {{ board.platformio_board }} ({{ board.chip_variant }})
// Radio:  {{ radiolib_class }}  |  Region {{ region }} sub-band {{ sub_band }}
//
// RadioLib + LoRaWAN_ESP32. NVS keeps DevNonces + session across reboots (the
// dominant cause of OTAA re-join rejection). When NVS is empty, persist.manage()
// prompts for band/sub-band + keys over serial -- the host-driven provisioning
// hook. The uplink payload is packed big-endian from a field spec shared with
// the ChirpStack decodeUplink codec on the device profile.

#include <RadioLib.h>
#include <LoRaWAN_ESP32.h>
{% if has_axp or has_oled %}
#include <Wire.h>
{% endif %}
{% if has_axp %}
#define XPOWERS_CHIP_AXP192
#include "XPowersLib.h"
{% endif %}
{% if has_gps %}
#include <TinyGPS++.h>
{% endif %}
{% if has_dht %}
#include <DHT.h>
{% endif %}
{% if has_oled %}
#include <Adafruit_SSD1306.h>
{% endif %}

// {{ radiolib_class }} wiring on this board: NSS={{ cs }}, IRQ={{ irq }}, RST={{ rst }}, {{ 'BUSY' if is_sx126x else 'DIO1' }}={{ gpio }}.
{{ radiolib_class }} radio = new Module({{ cs }}, {{ irq }}, {{ rst }}, {{ gpio }});

LoRaWANNode* node;

// Survives deep sleep / soft reset (cleared on power-on); a coarse boot counter.
RTC_DATA_ATTR uint16_t bootCount = 0;
{% if has_axp %}
XPowersPMU power;            // AXP192 PMIC: gates the GPS + LoRa rails, reports battery
uint16_t batteryMv = 0;
{% endif %}
{% if has_gps %}
TinyGPSPlus gps;
HardwareSerial GPSSerial(1);
{% endif %}
{% if has_dht %}
DHT dht({{ dht_pin }}, DHT22);
float dhtTempC = 0.0;
float dhtHumidity = 0.0;
{% endif %}
{% if has_oled %}
// Reset is pulsed explicitly in setup() (after Vext power-on), so pass -1 here.
Adafruit_SSD1306 display(128, 64, &Wire, -1);
bool oledReady = false;     // false when the OLED is absent/wedged; loop() skips it then
// Serial breadcrumbs through OLED bring-up: each step prints + flushes before it
// runs, so a hang shows up as "the last line you saw". Flip to 0 once the
// bus-recovery path is confirmed on the target hardware.
#define WS_OLED_DEBUG 1
#if WS_OLED_DEBUG
#define WSDBG(msg) do { Serial.println(msg); Serial.flush(); delay(5); } while (0)
#else
#define WSDBG(msg) do {} while (0)
#endif
{% endif %}

// Pinned LoRaWAN parameters. The gateway is US915 sub-band 2; a mismatch makes
// the device transmit joins on channels the gateway never hears.
static const char*    WS_REGION   = "{{ region }}";
static const uint8_t  WS_SUBBAND  = {{ sub_band }};
static const uint64_t WS_JOIN_EUI = 0x{{ join_eui }}ULL;

void setup() {
  Serial.begin(115200);
  bootCount++;
  Serial.printf("wirestudio lorawan: %s sub-band %u joinEUI %016llX\n",
                WS_REGION, WS_SUBBAND, (unsigned long long) WS_JOIN_EUI);
{% if has_axp %}
  if (power.begin(Wire, AXP192_SLAVE_ADDRESS, {{ i2c_sda }}, {{ i2c_scl }})) {
    power.setLDO2Voltage(3300); power.enableLDO2();  // LoRa rail
    power.setLDO3Voltage(3300); power.enableLDO3();  // GPS rail
    power.enableBattDetection();
    power.enableBattVoltageMeasure();
    Serial.println("AXP192: LoRa + GPS rails enabled");
  } else {
    Serial.println("AXP192 init failed (battery/GPS telemetry unavailable)");
  }
{% endif %}
{% if has_gps %}
  GPSSerial.begin({{ gps_baud }}, SERIAL_8N1, {{ gps_rx }}, {{ gps_tx }});  // RX, TX
{% endif %}
{% if has_dht %}
  dht.begin();
{% endif %}
{% if has_oled %}
{% if oled_vext is not none %}
  pinMode({{ oled_vext }}, OUTPUT);
  digitalWrite({{ oled_vext }}, LOW);  // Vext low = OLED power on
  delay(100);                          // let the OLED rail settle before reset/init
{% endif %}
{% if oled_reset is not none %}
  pinMode({{ oled_reset }}, OUTPUT);   // explicit reset pulse (Heltec sequence)
  digitalWrite({{ oled_reset }}, HIGH); delay(1);
  digitalWrite({{ oled_reset }}, LOW);  delay(20);
  digitalWrite({{ oled_reset }}, HIGH);
{% endif %}
  // I2C bus recovery BEFORE handing the pins to Wire. An onboard SSD1306 that
  // came up half-initialised can hold SDA low; that wedges Wire.begin() / the
  // first transaction long enough to trip the interrupt watchdog (TG1WDT), and
  // a transaction timeout does NOT rescue a bus already stuck low (this is why
  // the earlier probe-with-timeout still boot-looped). Clock SCL up to 9 times
  // to let the slave finish its byte and release SDA, then issue a STOP.
  WSDBG("oled: bus-recover");
  pinMode({{ oled_sda }}, INPUT_PULLUP);
  pinMode({{ oled_scl }}, INPUT_PULLUP);
  delay(1);
  if (digitalRead({{ oled_sda }}) == LOW) {
    pinMode({{ oled_scl }}, OUTPUT);
    for (int i = 0; i < 9 && digitalRead({{ oled_sda }}) == LOW; i++) {
      digitalWrite({{ oled_scl }}, LOW);  delayMicroseconds(5);
      digitalWrite({{ oled_scl }}, HIGH); delayMicroseconds(5);
    }
    pinMode({{ oled_sda }}, OUTPUT);        // STOP: SDA low->high while SCL high
    digitalWrite({{ oled_sda }}, LOW);  delayMicroseconds(5);
    digitalWrite({{ oled_scl }}, HIGH); delayMicroseconds(5);
    digitalWrite({{ oled_sda }}, HIGH); delayMicroseconds(5);
    pinMode({{ oled_sda }}, INPUT_PULLUP);
    pinMode({{ oled_scl }}, INPUT_PULLUP);
  }
  WSDBG("oled: wire-begin");
  Wire.begin({{ oled_sda }}, {{ oled_scl }});
  Wire.setClock(100000);                 // 100 kHz: most tolerant of marginal onboard wiring
  Wire.setTimeOut(50);                   // ms; bound each I2C transaction (ESP32 core)
  WSDBG("oled: probe");
  Wire.beginTransmission({{ oled_addr }});
  bool oledPresent = (Wire.endTransmission() == 0);
  WSDBG(oledPresent ? "oled: present" : "oled: absent");
  if (oledPresent && display.begin(SSD1306_SWITCHCAPVCC, {{ oled_addr }})) {
    oledReady = true;
    display.clearDisplay();
    display.setTextSize(1);
    display.setTextColor(SSD1306_WHITE);
    display.setCursor(0, 0);
    display.println("wirestudio");
    display.display();
  } else {
    Serial.println("OLED absent or init failed; continuing without display");
  }
  WSDBG("oled: done");
{% endif %}

  int16_t state = radio.begin();
  if (state != RADIOLIB_ERR_NONE) {
    Serial.printf("radio.begin() failed: %d\n", state);
  }
{% if is_sx126x %}
  // SX126x: TCXO reference voltage + DIO2 drives the TX/RX RF switch.
  radio.setTCXO({{ tcxo_voltage }});
  radio.setDio2AsRfSwitch({{ 'true' if dio2_as_rf_switch else 'false' }});
{% endif %}
  node = persist.manage(&radio);

  if (node->isActivated()) {
    Serial.println("JOINED: OTAA session active");
  } else {
    Serial.println("JOIN FAILED: not activated (check keys + gateway coverage; retries on reboot)");
  }
  // US915 DR0 (SF10) caps the app payload at 11 bytes; this {{ payload_size }}-byte
  // payload needs at least DR{{ min_datarate }}. ADR tunes the rate from here.
  node->setDatarate({{ min_datarate }});
}

void loop() {
  // Host command channel: "wipe" clears stored provisioning + session (e.g. to
  // recover from an offline test's throwaway keys) and reboots to re-provision.
  if (Serial.available()) {
    Serial.setTimeout(100);
    String cmd = Serial.readStringUntil('\n');
    cmd.trim();
    if (cmd == "wipe") {
      Serial.println("wiping provisioning + session; rebooting...");
      persist.wipe();
      delay(200);
      ESP.restart();
    }
  }

  // Sensors + OLED refresh every iteration, independent of the LoRaWAN join,
  // so you get live feedback even with no gateway in range. The uplink (and a
  // re-join retry) run on a 60s cadence.
{% if has_gps %}
  while (GPSSerial.available()) gps.encode(GPSSerial.read());  // keep the fix current
{% endif %}
{% if has_oled %}
  if (oledReady) {
    display.clearDisplay();
    display.setCursor(0, 0);
{% if has_gps %}
    display.printf("Sats:%lu %s\n", (unsigned long) gps.satellites.value(),
                   gps.location.isValid() ? "FIX" : "...");
    display.printf("Lat: %.5f\n", gps.location.lat());
    display.printf("Lon: %.5f\n", gps.location.lng());
{% endif %}
{% if has_axp %}
    display.printf("Batt: %u mV\n", batteryMv);
{% endif %}
{% if has_dht %}
    display.printf("Temp: %.1f C\n", dhtTempC);
{% endif %}
    display.printf("LoRa: %s\n", node->isActivated() ? "joined" : "no join");
    display.display();
  }
{% endif %}

  static unsigned long lastTx = 0;
  if (lastTx == 0 || millis() - lastTx >= 60000) {
    lastTx = millis();
{% if has_axp %}
    batteryMv = power.getBattVoltage();
{% endif %}
{% if has_dht %}
    {
      float _t = dht.readTemperature();
      float _h = dht.readHumidity();
      if (!isnan(_t)) dhtTempC = _t;
      if (!isnan(_h)) dhtHumidity = _h;
    }
{% endif %}
{% if has_gps %}
    Serial.printf("GPS: %s sats=%lu lat=%.6f lon=%.6f\n",
                  gps.location.isValid() ? "fix" : "no-fix",
                  (unsigned long) gps.satellites.value(), gps.location.lat(), gps.location.lng());
{% endif %}
{% if has_axp %}
    Serial.printf("battery: %u mV\n", batteryMv);
{% endif %}
{% if has_dht %}
    Serial.printf("dht: %.1f C  %.0f%%\n", dhtTempC, dhtHumidity);
{% endif %}
    if (!node->isActivated()) {
      Serial.println("not joined -- retrying OTAA (sensors still live above)");
      node->activateOTAA();
      persist.saveSession(node);
    }
    if (node->isActivated()) {
      // Payload packed big-endian from the generated field spec (codec.py),
      // in lockstep with the ChirpStack decodeUplink codec on the profile.
      uint8_t payload[{{ payload_size }}];
{{ payload_pack }}
      int16_t state = node->sendReceive(payload, sizeof(payload));
      Serial.printf("uplink: RadioLib state %d\n", state);
      persist.saveSession(node);
    }
  }
  delay(500);
}
